{
    "workbench.colorTheme": "GitHub Dark",
    "[python]": {
        "editor.formatOnType": true
    },
    "workbench.startupEditor": "none",
    "workbench.iconTheme": "material-icon-theme",
    "terminal.integrated.defaultProfile.windows": "Ubuntu (WSL)",
    "explorer.confirmDelete": false,
    "editor.inlineSuggest.enabled": true,
    "github.copilot.enable": {
        "*": false
    },
    "security.workspace.trust.untrustedFiles": "open",
    "git.confirmSync": false,
    "python.defaultInterpreterPath": "C:\\Users\\Michal\\AppData\\Local\\Programs\\Python\\Python311\\python.exe",
    "workbench.editorAssociations": {
        "*.pdf": "latex-workshop-pdf-hook"
    },
    "workbench.sideBar.location": "right",
    "explorer.confirmDragAndDrop": false,
    "kotlin.languageServer.enabled": false,
    "kotlin.debugAdapter.enabled": false,
    "git.autofetch": true,
    "redhat.telemetry.enabled": true,
    "vs-kubernetes": {
        "vscode-kubernetes.helm-path-windows": "C:\\Users\\Michal\\.vs-kubernetes\\tools\\helm\\windows-amd64\\helm.exe",
        "vscode-kubernetes.minikube-path-windows": "C:\\Users\\Michal\\.vs-kubernetes\\tools\\minikube\\windows-amd64\\minikube.exe"
    },
    "github.copilot.editor.enableAutoCompletions": true,
    "git.openRepositoryInParentFolders": "always",
    "update.showReleaseNotes": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "githubPullRequests.pullBranch": "never",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash"
        },
        "Ubuntu (WSL)": {
            "path": "C:\\WINDOWS\\System32\\wsl.exe",
            "args": [
                "-d",
                "Ubuntu"
            ]
        }
    },
    "[latex]": {
        "editor.defaultFormatter": "James-Yu.latex-workshop"
    },
    "hediet.vscode-drawio.resizeImages": null,
    "github.copilot.chat.setupTests.enabled": false,
    "roo-cline.allowedCommands": [
        "npm test",
        "npm install",
        "tsc",
        "git log",
        "git diff",
        "git show"
    ],
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "liveshare.accessibility.soundsEnabled": false,
    "accessibility.signalOptions.volume": 0,
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "jupyter.askForKernelRestart": false
}