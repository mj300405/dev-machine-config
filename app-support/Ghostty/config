# Ghostty Configuration
# Location: ~/Library/Application Support/com.mitchellh.ghostty/config

# Quick Terminal Toggle - just press § (section key under ESC)
# Using Unicode codepoint for § character (U+00A7)
keybind = global:§=toggle_quick_terminal

# Quick terminal size (22 lines of 14 px)
quick-terminal-size = 40%
quick-terminal-position = bottom

# Font - JetBrains Mono
font-family = JetBrains Mono
font-size = 14

# Theme - Github dark (built-in)
theme = GitHub Dark

# Background styling
background-opacity = 0.95
background-blur-radius = 20

# Cursor
cursor-style = bar
cursor-style-blink = false

# Window padding
window-padding-x = 8
window-padding-y = 8

# macOS settings
macos-titlebar-style = tabs
macos-option-as-alt = left

# Window theme
window-theme = auto

# Split panes
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# Navigate splits
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
keybind = cmd+up=goto_split:top
keybind = cmd+down=goto_split:bottom

# Tabs
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface

# Font size
keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size

# Clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

# Shell integration
shell-integration = detect

# Confirm before closing
confirm-close-surface = true
